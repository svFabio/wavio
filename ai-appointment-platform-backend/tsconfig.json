{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "lib": [
      "es2020",
      "dom"
    ],
    "types": [
      "node"
    ],
    "rootDir": ".",
    "outDir": "./dist",
    "esModuleInterop": true,
    "strict": false,
    "verbatimModuleSyntax": false,
    "skipLibCheck": true
  },
  "include": [
    "src/**/*",
    "prisma/**/*",
    "scripts/**/*"
  ]
}