// backend/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Rol {
  ADMIN
  STAFF
}

enum DireccionMensaje {
  ENTRANTE
  SALIENTE
}

enum Plan {
  FREE
  PRO
}

// ─── TENANT (el negocio que se registra) ─────────────────────────────────────
model Negocio {
  id       Int    @id @default(autoincrement())
  googleId String @unique
  email    String @unique
  nombre   String @default("Mi Negocio")
  plan     Plan   @default(FREE)

  // ─── META CLOUD API FIELDS ───
  waAccessToken   String?
  waPhoneNumberId String? @unique
  waWabaId        String?
  waAppId         String?
  isWaConnected   Boolean @default(false)

  // ─── GOOGLE CALENDAR FIELDS ───
  googleCalendarAccessToken  String?
  googleCalendarRefreshToken String?
  googleCalendarId           String?
  isGoogleCalendarConnected  Boolean @default(false)

  creadoEn DateTime @default(now())

  usuarioNegocios    UsuarioNegocio[]
  citas              Cita[]
  sesionesChat       SesionChat[]
  mensajesChat       MensajeChat[]
  configuracion      Configuracion?
  servicios          Servicio[]
  horariosNegocio    HorarioNegocio[]
  horariosEspeciales HorarioEspecial[]
  clientes           Cliente[]
  listaEspera        ListaEspera[]
  pushSubscriptions  PushSubscription[]
}

// ─── USUARIO-NEGOCIO (M:N junction) ──────────────────────────────────────────
model UsuarioNegocio {
  usuarioId Int
  negocioId Int
  rol       Rol      @default(STAFF)
  creadoEn  DateTime @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  negocio Negocio @relation(fields: [negocioId], references: [id], onDelete: Cascade)

  @@id([usuarioId, negocioId])
  @@index([negocioId])
}

// ─── USUARIO (staff/admin del negocio) ───────────────────────────────────────
model Usuario {
  id         Int      @id @default(autoincrement())
  nombre     String
  email      String   @unique
  password   String   @default("")
  googleId   String?
  fotoPerfil String?
  rol        Rol      @default(STAFF)
  creadoEn   DateTime @default(now())

  usuarioNegocios UsuarioNegocio[]

  horarioStaff HorarioStaff[]
  citas        Cita[]         @relation("StaffCitas")

  @@index([googleId])
}

// ─── SESIÓN DE CHAT (por negocio) ────────────────────────────────────────────
model SesionChat {
  id            String
  estado        String
  datos         Json
  ultimoMensaje DateTime @default(now())

  negocioId Int
  negocio   Negocio @relation(fields: [negocioId], references: [id], onDelete: Cascade)

  @@id([id, negocioId])
  @@index([negocioId, ultimoMensaje])
}

// ─── SERVICIO (catálogo de servicios del negocio) ────────────────────────────
model Servicio {
  id              Int      @id @default(autoincrement())
  negocioId       Int
  nombre          String
  categoria       String? // e.g., "Masajes", "Faciales", "Depilación"
  duracionMinutos Int      @default(60)
  bufferMinutos   Int      @default(10)
  precio          Float    @default(0)
  activo          Boolean  @default(true)
  creadoEn        DateTime @default(now())

  negocio Negocio @relation(fields: [negocioId], references: [id], onDelete: Cascade)
  citas   Cita[]

  @@unique([negocioId, nombre])
  @@index([negocioId])
}

// ─── HORARIO REGULAR DEL NEGOCIO ─────────────────────────────────────────────
// Supports multiple blocks per day (e.g., 09:00-13:00 and 14:00-18:00)
model HorarioNegocio {
  id         Int     @id @default(autoincrement())
  negocioId  Int
  diaSemana  Int // 0=domingo, 1=lunes, ..., 6=sabado
  horaInicio String // "09:00"
  horaFin    String // "13:00"
  activo     Boolean @default(true)

  negocio Negocio @relation(fields: [negocioId], references: [id], onDelete: Cascade)

  @@unique([negocioId, diaSemana, horaInicio])
  @@index([negocioId])
}

// ─── HORARIO POR STAFF ───────────────────────────────────────────────────────
model HorarioStaff {
  id         Int     @id @default(autoincrement())
  usuarioId  Int
  diaSemana  Int // 0=domingo, 1=lunes, ..., 6=sabado
  horaInicio String
  horaFin    String
  activo     Boolean @default(true)

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, diaSemana, horaInicio])
  @@index([usuarioId])
}

// ─── HORARIO ESPECIAL (feriados, vacaciones, horario extendido) ──────────────
model HorarioEspecial {
  id         Int      @id @default(autoincrement())
  negocioId  Int
  fecha      DateTime @db.Date
  cerrado    Boolean  @default(false)
  horaInicio String?
  horaFin    String?

  negocio Negocio @relation(fields: [negocioId], references: [id], onDelete: Cascade)

  @@unique([negocioId, fecha])
  @@index([negocioId])
}

// ─── CLIENTE ──────────────────────────────────────────────────────────────────
model Cliente {
  id          Int     @id @default(autoincrement())
  negocioId   Int
  nombre      String
  telefono    String
  email       String?
  notas       String?
  noShowCount Int     @default(0)
  blocked     Boolean @default(false)

  magicToken      String?   @unique
  magicLinkExpiry DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  negocio Negocio @relation(fields: [negocioId], references: [id], onDelete: Cascade)

  @@unique([negocioId, telefono])
  @@index([negocioId])
}

// ─── CITA ─────────────────────────────────────────────────────────────────────
model Cita {
  id              Int      @id @default(autoincrement())
  fecha           DateTime
  horario         String
  clienteNombre   String?
  clienteTelefono String
  servicio        String   @default("Spa")
  servicioId      Int?

  duracionMinutos Int      @default(60)
  staffId         Int?
  estadoPago      String   @default("PENDIENTE")
  monto           Decimal  @db.Decimal(10, 2)
  estado          String   @default("PENDIENTE")
  comprobanteUrl  String?
  descripcion     String?
  origen          String   @default("virtual")
  recordatorio24h Boolean  @default(false)
  recordatorio1h  Boolean  @default(false)
  encuestaEnviada Boolean  @default(false)
  rating          Int?
  comentario      String?
  creadoEn        DateTime @default(now())

  // ─── RECURRENCE FIELDS ───
  recurrence    String? // none, weekly, biweekly, monthly
  recurrenceId  String? // groups all instances of a recurring series
  recurrenceEnd DateTime? // when to stop generating instances

  negocioId   Int
  negocio     Negocio   @relation(fields: [negocioId], references: [id], onDelete: Cascade)
  servicioRef Servicio? @relation(fields: [servicioId], references: [id])
  staff       Usuario?  @relation("StaffCitas", fields: [staffId], references: [id])

  @@index([negocioId, fecha, estado])
  @@index([recurrenceId])
}

// ─── HISTORIAL DE MENSAJES ───────────────────────────────────────────────────
model MensajeChat {
  id            Int              @id @default(autoincrement())
  waMessageId   String?          @unique
  remoteJid     String
  contenido     String
  direccion     DireccionMensaje
  estadoEntrega String           @default("enviado")
  timestamp     DateTime         @default(now())

  negocioId Int
  negocio   Negocio @relation(fields: [negocioId], references: [id], onDelete: Cascade)

  @@index([negocioId, remoteJid, timestamp])
}

// ─── CONFIGURACIÓN DEL BOT ────────────────────────────────────────────────────
// NOTE: servicios and horarios fields were REMOVED.
// They are now in their own tables: Servicio and HorarioNegocio.
model Configuracion {
  id                  Int     @id @default(autoincrement())
  trigger             String  @default("!cita")
  mensajeBienvenida   String  @default("Hola! Soy el asistente de citas. Cual es tu nombre completo?")
  mensajeConfirmacion String  @default("Comprobante recibido! Tu cita esta siendo revisada. Te confirmamos pronto.")
  qrContenido         String  @default("TU_CODIGO_QR_AQUI")
  qrFotoUrl           String?
  cobrarAdelanto      Boolean @default(true)
  porcentajeAdelanto  Int     @default(50)
  timezone            String  @default("America/La_Paz")
  chatFlow            Json    @default("{}")

  negocioId Int     @unique
  negocio   Negocio @relation(fields: [negocioId], references: [id], onDelete: Cascade)
}

// ─── LISTA DE ESPERA ─────────────────────────────────────────────────────────
model ListaEspera {
  id               Int       @id @default(autoincrement())
  clienteNombre    String
  clienteTelefono  String
  servicioId       Int?
  fechaPreferida   DateTime
  horarioPreferido String?
  estado           String    @default("PENDIENTE") // PENDIENTE, NOTIFICADA, CONFIRMADA, CANCELADA
  notificadoEn     DateTime?
  creadoEn         DateTime  @default(now())

  negocioId Int
  negocio   Negocio @relation(fields: [negocioId], references: [id], onDelete: Cascade)

  @@index([negocioId, estado, fechaPreferida])
}

// ─── PUSH SUBSCRIPTION ─────────────────────────────────────────────────────
model PushSubscription {
  id        Int      @id @default(autoincrement())
  endpoint  String
  p256dh    String
  auth      String
  negocioId Int
  userId    Int?
  createdAt DateTime @default(now())

  negocio Negocio @relation(fields: [negocioId], references: [id], onDelete: Cascade)

  @@unique([endpoint])
  @@index([negocioId])
  @@index([userId])
}
