// backend/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Rol {
  ADMIN
  STAFF
}

enum Plan {
  FREE
  PRO
}

// ─── TENANT (el negocio que se registra) ─────────────────────────────────────
model Negocio {
  id        Int      @id @default(autoincrement())
  googleId  String   @unique // ID de Google del dueño que se registró
  email     String   @unique
  nombre    String   @default("Mi Negocio")
  plan      Plan     @default(FREE)
  creadoEn  DateTime @default(now())

  usuarios      Usuario[]
  citas         Cita[]
  sesionesChat  SesionChat[]
  mensajesChat  MensajeChat[]
  configuracion Configuracion?
}

// ─── USUARIO (staff/admin del negocio) ───────────────────────────────────────
model Usuario {
  id        Int      @id @default(autoincrement())
  nombre    String
  email     String   @unique
  password  String   @default("") // vacío para usuarios de Google; usado solo en dev seed
  googleId  String?  // ID de Google del usuario (opcional)
  rol       Rol      @default(STAFF)
  creadoEn  DateTime @default(now())

  negocioId Int
  negocio   Negocio @relation(fields: [negocioId], references: [id])
}

// ─── SESIÓN BAILEYS (por negocio) ────────────────────────────────────────────
model BaileysSession {
  id    String @id
  creds String @db.Text
  keys  String @db.Text
}

// ─── SESIÓN DE CHAT (por negocio) ────────────────────────────────────────────
model SesionChat {
  id            String   @id // remoteJid
  estado        String
  datos         Json
  ultimoMensaje DateTime @default(now())

  negocioId Int
  negocio   Negocio @relation(fields: [negocioId], references: [id])

  @@index([negocioId, ultimoMensaje])
}

// ─── CITA ─────────────────────────────────────────────────────────────────────
model Cita {
  id              Int      @id @default(autoincrement())
  fecha           DateTime
  horario         String
  clienteNombre   String?
  clienteTelefono String
  servicio        String   @default("Spa")
  monto           Float
  estado          String   @default("PENDIENTE")
  comprobanteUrl  String?
  descripcion     String?
  origen          String   @default("virtual")
  recordatorio24h Boolean  @default(false)
  recordatorio1h  Boolean  @default(false)
  encuestaEnviada Boolean  @default(false)
  rating          Int?
  comentario      String?
  creadoEn        DateTime @default(now())

  negocioId Int
  negocio   Negocio @relation(fields: [negocioId], references: [id])

  @@index([negocioId, fecha])
}

// ─── HISTORIAL DE MENSAJES ───────────────────────────────────────────────────
model MensajeChat {
  id        Int      @id @default(autoincrement())
  remoteJid String
  contenido String
  direccion String   // ENTRANTE | SALIENTE
  timestamp DateTime @default(now())

  negocioId Int
  negocio   Negocio @relation(fields: [negocioId], references: [id])

  @@index([negocioId, remoteJid, timestamp])
}

// ─── CONFIGURACIÓN DEL BOT ────────────────────────────────────────────────────
model Configuracion {
  id                  Int    @id @default(autoincrement())
  trigger             String @default("!cita")
  mensajeBienvenida   String @default("Hola! Soy el asistente de citas. Cual es tu nombre completo?")
  mensajeConfirmacion String @default("Comprobante recibido! Tu cita esta siendo revisada. Te confirmamos pronto.")
  servicios           Json   @default("[{\"nombre\":\"Servicio\",\"precio\":0}]")
  horarios            Json   @default("{\"lunes\":[\"09:00\",\"10:00\",\"11:00\",\"12:00\"],\"martes\":[\"09:00\",\"10:00\",\"11:00\",\"12:00\"],\"miercoles\":[\"09:00\",\"10:00\",\"11:00\",\"12:00\"],\"jueves\":[\"09:00\",\"10:00\",\"11:00\",\"12:00\"],\"viernes\":[\"09:00\",\"10:00\",\"11:00\",\"12:00\"],\"sabado\":[],\"domingo\":[]}")
  qrContenido         String  @default("TU_CODIGO_QR_AQUI")
  cobrarAdelanto      Boolean @default(true)
  porcentajeAdelanto  Int     @default(50)

  negocioId Int     @unique
  negocio   Negocio @relation(fields: [negocioId], references: [id])
}