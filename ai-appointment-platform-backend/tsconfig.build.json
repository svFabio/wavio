{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "outDir": "./dist"
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "test",
    "**/*spec.ts",
    "**/*test.ts",
    "src/routes/**/*",
    "src/controllers/**/*",
    "src/services/**/*",
    "src/repositories/**/*",
    "src/middleware/**/*",
    "src/server.ts"
  ]
}
